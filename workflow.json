    {
      "parameters": {
        "method": "POST",
        "url": "https://gigachat.devices.sberbank.ru/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Accept",
              "value": "application/json"
            },
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Set token').item.json.access_token }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"GigaChat\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": {{ JSON.stringify($json.content) }}\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($('Webhook').item.json.body.message.text) }}\n    }\n  ],\n  \"function_call\": {\n    \"name\": \"classify_ticket\"\n  },\n  \"functions\": [\n    {\n      \"name\": \"classify_ticket\",\n      \"description\": \"Классифицирует входящее обращение пользователя в службу поддержки. Определяет категорию, приоритет, краткое описание, исполнителя и уверенность в классификации.\",\n      \"parameters\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"category\": {\n            \"type\": \"string\",\n            \"description\": \"Категория обращения.\",\n            \"enum\": [\n              \"Техническая проблема\",\n              \"Проблема с доступом\",\n              \"Коммерческий вопрос\",\n              \"Другое\"\n            ]\n          },\n          \"priority\": {\n            \"type\": \"string\",\n            \"description\": \"Приоритет обращения. Высокий — бизнес-процесс остановлен. Средний — частичная проблема. Низкий — информационный вопрос.\",\n            \"enum\": [\n              \"Высокий\",\n              \"Средний\",\n              \"Низкий\"\n            ]\n          },\n          \"summary\": {\n            \"type\": \"string\",\n            \"description\": \"Краткое описание сути обращения в 2–3 предложениях. Только факты из текста, без домыслов. Должно быть достаточно для понимания без чтения оригинала.\"\n          },\n          \"assignee\": {\n            \"type\": \"string\",\n            \"description\": \"Предполагаемый исполнитель. Support — технические проблемы и доступ. Sales — коммерция и новые подключения. DevOps — сбои после обновлений ПО. Account Manager — лицензии и договоры существующих клиентов.\",\n            \"enum\": [\n              \"Support\",\n              \"Sales\",\n              \"DevOps\",\n              \"Account Manager\"\n            ]\n          },\n          \"confidence\": {\n            \"type\": \"number\",\n            \"description\": \"Уверенность в классификации от 0 до 1. 0.9–1.0 — однозначное обращение. 0.7–0.89 — небольшая неопределённость. Ниже 0.7 — размытое обращение.\"\n          }\n        },\n        \"required\": [\"category\", \"priority\", \"summary\", \"assignee\", \"confidence\"]\n      },\n      \"return_parameters\": {\n        \"type\": \"object\",\n        \"properties\": {\n          \"category\": { \"type\": \"string\" },\n          \"priority\": { \"type\": \"string\" },\n          \"summary\": { \"type\": \"string\" },\n          \"assignee\": { \"type\": \"string\" },\n          \"confidence\": { \"type\": \"number\" }\n        }\n      },\n      \"few_shot_examples\": [\n        {\n          \"request\": \"Здравствуйте.\\n\\nПосле обновления кассовой программы перестали печататься чеки.\\n\\nКинотеатр «Орион».\\n\\nОшибка возникает только на первой кассе.\",\n          \"params\": {\n            \"category\": \"Техническая проблема\",\n            \"priority\": \"Высокий\",\n            \"summary\": \"После обновления кассового ПО перестали печататься чеки на первой кассе кинотеатра «Орион». Проблема воспроизводится стабильно на одном рабочем месте. Требуется диагностика после обновления.\",\n            \"assignee\": \"DevOps\",\n            \"confidence\": 0.93\n          }\n        },\n        {\n          \"request\": \"Добрый день.\\n\\nХотим узнать стоимость подключения нового кинотеатра.\\n\\nНас интересуют лицензии.\",\n          \"params\": {\n            \"category\": \"Коммерческий вопрос\",\n            \"priority\": \"Низкий\",\n            \"summary\": \"Потенциальный клиент интересуется стоимостью подключения нового кинотеатра и условиями лицензирования. Конкретных технических вопросов нет.\",\n            \"assignee\": \"Sales\",\n            \"confidence\": 0.97\n          }\n        },\n        {\n          \"request\": \"Не могу войти в личный кабинет.\\n\\nПишет «неверный пароль».\\n\\nСбрасывал пароль два раза.\",\n          \"params\": {\n            \"category\": \"Проблема с доступом\",\n            \"priority\": \"Средний\",\n            \"summary\": \"Пользователь не может войти в личный кабинет — система выдаёт ошибку «неверный пароль». Двукратный сброс пароля проблему не решил. Возможна техническая неисправность механизма аутентификации.\",\n            \"assignee\": \"Support\",\n            \"confidence\": 0.95\n          }\n        },\n        {\n          \"request\": \"У нас не работает весь сервер — все кассы встали, сеанс через 20 минут.\",\n          \"params\": {\n            \"category\": \"Техническая проблема\",\n            \"priority\": \"Высокий\",\n            \"summary\": \"Полный отказ сервера: все кассы недоступны, продажи билетов остановлены. Ближайший сеанс через 20 минут, ситуация критическая.\",\n            \"assignee\": \"DevOps\",\n            \"confidence\": 0.99\n          }\n        },\n        {\n          \"request\": \"Хотели бы узнать, можно ли продлить лицензию на следующий год и какие условия.\",\n          \"params\": {\n            \"category\": \"Коммерческий вопрос\",\n            \"priority\": \"Низкий\",\n            \"summary\": \"Существующий клиент интересуется условиями и возможностью продления лицензии на следующий год.\",\n            \"assignee\": \"Account Manager\",\n            \"confidence\": 0.92\n          }\n        }\n      ]\n    }\n  ]\n}",
        "options": {
          "allowUnauthorizedCerts": true
        }
      },
